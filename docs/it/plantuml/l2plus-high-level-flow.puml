@startuml Flusso OAuth Autenticazione Multi-Step Alto Livello
!include <C4/C4_Component>
HIDE_STEREOTYPE()
!include <tupadr3/font-awesome-5/user>
!include <tupadr3/font-awesome-5/mobile_alt>
!include <tupadr3/font-awesome-5/shield_alt>
!include <tupadr3/font-awesome-5/key>
!include <tupadr3/font-awesome-5/file_alt>
!include <tupadr3/font-awesome-5/certificate>
!include <tupadr3/font-awesome-5/database>
!include <tupadr3/font-awesome-5/cogs>
!include <tupadr3/font-awesome-5/id_card>
!include <tupadr3/font-awesome-5/exchange_alt>
!include <tupadr3/font-awesome-5/wallet>
!include <tupadr3/font-awesome/institution>

' Definizioni stile personalizzate per le fasi del flusso
AddElementTag("phase1", $bgColor="#1168bd", $fontColor="white", $borderColor="#0b4884")
AddElementTag("phase2", $bgColor="#7b2d8e", $fontColor="white", $borderColor="#5a1f68")
'AddElementTag("phase3", $bgColor="#d73502", $fontColor="white", $borderColor="#a02701")
AddElementTag("phase3", $bgColor="#f18f01", $fontColor="white", $borderColor="#c17001")
AddElementTag("phase4", $bgColor="#2d5a27", $fontColor="white", $borderColor="#1e3d1b")

title
<size:18><b>Autenticazione eID Substantial con Verifica MRTD</b></size>
<size:14>Fasi Protocollo Alto Livello</size>
end title

'left to right direction

' Definisce le 5 fasi principali come da specifica input
Component(phase1, "Fase 1", "Richiesta Autorizzazione OAuth", "PAR e richiesta autorizzazione con requisiti challenge multi-step", $sprite="shield_alt", $tags="phase1")

Component(phase2, "Fase 2", "Autenticazione Primaria", "Identificazione elettronica LoA3 (SPID/CIEid L2)", $sprite="key", $tags="phase2")

'Component(phase3, "Fase 3", "Richiesta Challenge", "Requisito proof of possession documento", $sprite="id_card", $tags="phase3")

Component(phase3, "Fase 3", "Validazione PoP Documento", "Lettura documento elettronico e verifica crittografica", $sprite="id_card",$tags="phase3")

Component(phase4, "Fase 4", "Risposta Autorizzazione OAuth", "Emissione finale codice autorizzazione", $sprite="shield_alt",$tags="phase4")

' Flusso sequenziale tra le fasi
Rel_R(phase1, phase2, "Procedi ad Autenticazione", "Challenge multi-step iniziata")
Rel_R(phase2, phase3, "Identita Verificata", "Attiva challenge PoP documento")
'Rel_R(phase3, phase4, "Documento Richiesto", "Inizia validazione PoP")
Rel_R(phase3, phase4, "PoP Validato", "Completa autorizzazione")
@enduml